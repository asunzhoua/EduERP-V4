/* pages/teacher/class-detail.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 加载/错误状态 */
.loading-state, .error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e6f7ff;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.retry-btn {
  padding: 16rpx 40rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 头部 */
.detail-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.class-name {
  font-size: 36rpx;
  font-weight: bold;
}

.class-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.2);
}

.class-schedule {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 12rpx;
}

.course-info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.course-label {
  opacity: 0.7;
  margin-right: 8rpx;
}

.course-name {
  opacity: 0.9;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.tab-item.active {
  color: #1890ff;
  background: #e6f7ff;
  font-weight: 500;
}

/* Tab 内容 */
.tab-content {
  min-height: 400rpx;
}

/* 信息区块 */
.info-section {
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 学生列表 */
.students-panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.panel-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.view-all {
  font-size: 24rpx;
  color: #1890ff;
}

.student-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.student-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.student-name {
  font-size: 26rpx;
  color: #333;
}

.student-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-ENROLLED {
  background: #f6ffed;
  color: #52c41a;
}

.status-LEAVE {
  background: #fff7e6;
  color: #fa8c16;
}

.empty-hint {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 课时记录 */
.lessons-panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.progress-card {
  margin-bottom: 24rpx;
}

.progress-bar {
  height: 16rpx;
  background: #e8e8e8;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a 0%, #73d13d 100%);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 12rpx;
  display: block;
  text-align: center;
}

.record-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}