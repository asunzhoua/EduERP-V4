<!--pages/teacher/class-detail.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:elif="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="retryLoad">重试</button>
  </view>

  <!-- 班级详情 -->
  <view class="detail-content" wx:else>
    <!-- 头部信息 -->
    <view class="detail-header">
      <view class="header-top">
        <text class="class-name">{{classInfo.name}}</text>
        <text class="class-status status-{{classInfo.status}}">
          {{classInfo.status === 'ACTIVE' ? '进行中' : classInfo.status === 'COMPLETED' ? '已结束' : classInfo.status === 'DRAFT' ? '草稿' : classInfo.status === 'CANCELLED' ? '已取消' : classInfo.status}}
        </text>
      </view>
      <text class="class-schedule">{{classInfo.schedule}}</text>
      <view class="course-info">
        <text class="course-label">课程:</text>
        <text class="course-name">{{classInfo.courseName}}</text>
      </view>
    </view>

    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view 
        class="tab-item {{activeTab === 'info' ? 'active' : ''}}"
        bindtap="onTabChange"
        data-tab="info"
      >
        基本信息
      </view>
      <view 
        class="tab-item {{activeTab === 'students' ? 'active' : ''}}"
        bindtap="onTabChange"
        data-tab="students"
      >
        学生列表
      </view>
      <view 
        class="tab-item {{activeTab === 'lessons' ? 'active' : ''}}"
        bindtap="onTabChange"
        data-tab="lessons"
      >
        课时记录
      </view>
    </view>

    <!-- Tab 内容 -->
    <view class="tab-content">
      <!-- 基本信息 -->
      <view class="info-panel" wx:if="{{activeTab === 'info'}}">
        <view class="info-section">
          <view class="section-title">班级信息</view>
          <view class="info-list">
            <view class="info-item">
              <text class="info-label">班级编码</text>
              <text class="info-value">{{classInfo.classCode}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">开班日期</text>
              <text class="info-value">{{classInfo.startDate}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">结课日期</text>
              <text class="info-value">{{classInfo.endDate}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">学生人数</text>
              <text class="info-value">{{classInfo.currentStudents}}/{{classInfo.maxStudents}}人</text>
            </view>
            <view class="info-item">
              <text class="info-label">课时进度</text>
              <text class="info-value">{{classInfo.completedLessons}}/{{classInfo.totalLessons}}节</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 学生列表 -->
      <view class="students-panel" wx:if="{{activeTab === 'students'}}">
        <view class="panel-header">
          <text class="panel-title">学生 ({{students.length}})</text>
          <text class="view-all" bindtap="goToStudents">查看全部 ></text>
        </view>
        <view class="student-list" wx:if="{{students.length > 0}}">
          <view class="student-item" wx:for="{{students}}" wx:key="id" bindtap="goToStudentDetail" data-code="{{item.studentCode}}">
            <text class="student-name">{{item.name}}</text>
            <text class="student-status status-{{item.status}}">{{item.status === 'ENROLLED' ? '在读' : '请假'}}</text>
          </view>
        </view>
        <view class="empty-hint" wx:else>
          <text>暂无学生，点击添加</text>
        </view>
      </view>

      <!-- 课时记录 -->
      <view class="lessons-panel" wx:if="{{activeTab === 'lessons'}}">
        <view class="panel-header">
          <text class="panel-title">课时进度</text>
        </view>
        <view class="progress-card">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{classInfo.totalLessons > 0 ? (classInfo.completedLessons / classInfo.totalLessons) * 100 : 0}}%"></view>
          </view>
          <text class="progress-text">{{classInfo.completedLessons}}/{{classInfo.totalLessons}} 节课</text>
        </view>

        <!-- 课时列表 -->
        <view class="lesson-list" wx:if="{{lessons.length > 0}}">
          <view class="lesson-item" wx:for="{{lessons}}" wx:key="id">
            <view class="lesson-left">
              <text class="lesson-number">第{{item.lessonNumber}}课时</text>
              <text class="lesson-date">{{item.scheduledDate}}</text>
            </view>
            <view class="lesson-right">
              <text class="lesson-status status-{{item.status}}">
                {{item.status === 'FINISHED' ? '已完成' : item.status === 'TEACHING' ? '进行中' : item.status === 'CANCELLED' ? '已取消' : '未开始'}}
              </text>
              <text class="lesson-note" wx:if="{{item.note}}">{{item.note}}</text>
            </view>
          </view>
        </view>
        <view class="empty-hint" wx:elif="{{lessonsLoading}}">
          <text>加载中...</text>
        </view>
        <view class="empty-hint" wx:else>
          <text>暂无课时记录</text>
        </view>

        <button class="record-btn" bindtap="goToRecordLesson">记录课时</button>
      </view>
    </view>
  </view>
</view>