/* pages/teacher/student-detail/index.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 加载/错误状态 */
.loading-state, .error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e6f7ff;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.retry-btn {
  padding: 16rpx 40rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 个人信息卡片 */
.profile-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.profile-info {
  flex: 1;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
}

.profile-gender {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 2rpx 12rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 6rpx;
}

.profile-school {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 信息区块 */
.info-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 班级区块 */
.class-section {
  margin-bottom: 20rpx;
}

.section-header {
  padding: 0 0 16rpx 0;
}

.class-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.class-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.class-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.class-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.class-code {
  font-size: 22rpx;
  color: #999;
}

.class-mid {
  margin-bottom: 12rpx;
}

.class-course {
  font-size: 26rpx;
  color: #666;
}

.class-progress {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #52c41a);
  border-radius: 8rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
}

.empty {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 操作区域 */
.action-section {
  padding: 10rpx 0 40rpx;
}

.action-btn {
  width: 100%;
  padding: 24rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
}
