/* pages/teacher/courses.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 30rpx;
  background: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.course-list {
  margin-top: 20rpx;
}

.course-card {
  background: #ffffff;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.course-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-PUBLISHED {
  background: #e6f7ff;
  color: #1890ff;
}

.status-DRAFT {
  background: #fff7e6;
  color: #fa8c16;
}

.status-ARCHIVED {
  background: #f5f5f5;
  color: #999999;
}

.course-info {
  display: flex;
  gap: 20rpx;
}

.course-code, .course-subject {
  font-size: 24rpx;
  color: #999999;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999999;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1890ff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.fab-icon {
  font-size: 48rpx;
  color: #ffffff;
}