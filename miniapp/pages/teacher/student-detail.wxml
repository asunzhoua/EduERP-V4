<!--pages/teacher/student-detail/index.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:elif="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="retryLoad">重试</button>
  </view>

  <block wx:else>
    <!-- 个人信息卡片 -->
    <view class="profile-card">
      <view class="profile-avatar">
        <image src="/images/default-avatar.png" mode="aspectFill" class="avatar-img"></image>
      </view>
      <view class="profile-info">
        <view class="profile-header">
          <text class="profile-name">{{student.name}}</text>
          <text class="profile-gender">{{student.gender === 'MALE' ? '男' : student.gender === 'FEMALE' ? '女' : student.gender}}</text>
        </view>
        <view class="profile-school">
          <text>{{student.school}} · {{student.grade}}</text>
        </view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="info-section">
      <view class="section-title">联系方式</view>
      <view class="info-item">
        <text class="info-label">电话</text>
        <text class="info-value">{{student.phone || '未填写'}}</text>
      </view>
    </view>

    <!-- 所属班级 -->
    <view class="class-section">
      <view class="section-header">
        <text class="section-title">所属班级</text>
      </view>

      <view class="class-list">
        <view
          class="class-card"
          wx:for="{{classes}}"
          wx:key="classCode"
          bindtap="goToClassDetail"
          data-code="{{item.classCode}}"
        >
          <view class="class-top">
            <text class="class-name">{{item.name || item.courseName}}</text>
            <text class="class-code">{{item.classCode}}</text>
          </view>
          <view class="class-mid">
            <text class="class-course">{{item.courseName}}</text>
          </view>
          <view class="class-progress">
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{item.totalLessons > 0 ? (item.completedLessons / item.totalLessons * 100) : 0}}%"></view>
            </view>
            <text class="progress-text">{{item.completedLessons || 0}}/{{item.totalLessons || 0}}</text>
          </view>
        </view>
      </view>

      <view class="empty" wx:if="{{classes.length === 0}}">
        <text>暂无班级信息</text>
      </view>
    </view>

    <!-- 出勤记录按钮 -->
    <view class="action-section">
      <button class="action-btn" bindtap="goToLessonRecord">查看出勤记录</button>
    </view>
  </block>
</view>
