/* pages/teacher/classes.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
}

.filter-item {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
  background: #ffffff;
  border-radius: 8rpx;
}

.filter-item.active {
  color: #ffffff;
  background: #1890ff;
}

.class-list {
  margin-top: 20rpx;
}

.class-card {
  background: #ffffff;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
}

.class-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.class-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.class-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-ACTIVE {
  background: #f6ffed;
  color: #52c41a;
}

.status-COMPLETED {
  background: #f5f5f5;
  color: #999999;
}

.status-DRAFT {
  background: #fff7e6;
  color: #fa8c16;
}

.class-info {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
}

.course-name {
  font-size: 28rpx;
  color: #666666;
}

.start-date {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.class-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.student-count {
  display: flex;
  align-items: baseline;
}

.count-current {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
}

.count-sep, .count-max {
  font-size: 28rpx;
  color: #999999;
  margin: 0 4rpx;
}

.count-label {
  font-size: 24rpx;
  color: #999999;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  background: #1890ff;
  color: #ffffff;
  border-radius: 8rpx;
}

.empty {
  text-align: center;
  padding: 60rpx;
  color: #999999;
}