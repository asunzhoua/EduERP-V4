/* pages/teacher/lesson-record.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 步骤指示器 */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
  background: #ffffff;
  margin-bottom: 20rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8e8e8;
  color: #999999;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
}

.step.active .step-circle {
  background: #1890ff;
  color: #ffffff;
}

.step-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.step.active .step-text {
  color: #1890ff;
}

.step-line {
  width: 40rpx;
  height: 4rpx;
  background: #e8e8e8;
  margin: 0 10rpx;
}

.step-line.active {
  background: #1890ff;
}

/* 内容区 */
.step-content {
  background: #ffffff;
  padding: 20rpx;
  border-radius: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hint {
  font-size: 24rpx;
  color: #999999;
}

/* 全局加载 */
.loading-bar {
  text-align: center;
  padding: 20rpx;
  color: #1890ff;
  font-size: 26rpx;
}

/* 空状态 */
.empty-hint {
  text-align: center;
  padding: 60rpx 20rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 班级列表 */
.class-list {
  margin-top: 20rpx;
}

.class-item {
  padding: 24rpx;
  margin-bottom: 12rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.class-item.selected {
  background: #e6f7ff;
  border-color: #1890ff;
}

.class-item .class-name {
  display: block;
  font-size: 32rpx;
  color: #333333;
}

.class-item .course-name {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 学生列表 */
.student-list {
  margin-top: 20rpx;
}

.student-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 12rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.student-item.status-PRESENT {
  background: #f6ffed;
}

.student-item.status-ABSENT {
  background: #fff2f0;
}

.student-item.status-LATE {
  background: #fff7e6;
}

.student-name {
  font-size: 32rpx;
  color: #333333;
}

.status-badge {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

/* 表单 */
.form {
  margin-top: 20rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item.half {
  flex: 1;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.required {
  color: #ff4d4f;
}

.picker {
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333333;
}

/* 表单验证错误样式 */
.has-error .picker {
  border: 2rpx solid #ff4d4f;
}

.picker-error {
  color: #ff4d4f !important;
}

.error-text {
  display: block;
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

.time-range-error {
  display: block;
  font-size: 24rpx;
  color: #ff4d4f;
  background: #fff2f0;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-top: -12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 确认卡片 */
.confirm-card {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
}

.confirm-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.confirm-item:last-child {
  border-bottom: none;
}

.confirm-label {
  font-size: 28rpx;
  color: #999999;
}

.confirm-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  max-width: 60%;
}

/* 提交状态 */
.submit-status {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #e6f7ff;
  border-radius: 8rpx;
  text-align: center;
}

.submit-loading text {
  font-size: 26rpx;
  color: #1890ff;
}

.submit-error {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #fff2f0;
  border: 2rpx solid #ffccc7;
  border-radius: 8rpx;
}

.submit-error .error-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-bottom: 8rpx;
}

.submit-error .error-detail {
  display: block;
  font-size: 24rpx;
  color: #666666;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #1890ff;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-primary:active {
  background: #096dd9;
}

.btn-disabled {
  background: #a0d1ff !important;
  color: #ffffff !important;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #ffffff;
  color: #666666;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-secondary:active {
  background: #f5f5f5;
}

/* 按钮禁用态 */
button[disabled] {
  opacity: 0.6;
}