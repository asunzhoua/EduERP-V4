/* pages/teacher/students.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 30rpx;
  background: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.student-list {
  margin-top: 20rpx;
}

.student-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 24rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #1890ff;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

.student-info {
  flex: 1;
  margin-left: 20rpx;
}

.student-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.student-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.student-gender {
  font-size: 24rpx;
  color: #999999;
}

.student-detail {
  margin-top: 8rpx;
}

.school-grade {
  font-size: 24rpx;
  color: #999999;
}

.student-code {
  font-size: 24rpx;
  color: #cccccc;
}

.empty {
  text-align: center;
  padding: 60rpx;
  color: #999999;
}