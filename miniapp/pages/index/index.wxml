<!--pages/index/index.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '未登录'}}</text>
      <text class="user-role">{{roleText}}</text>
    </view>
  </view>

  <!-- ========== 教师端快捷入口 ========== -->
  <view class="quick-actions" wx:if="{{role !== 'Student'}}">
    <view class="action-grid">
      <view class="action-item" bindtap="goToCourses">
        <text class="action-icon">📚</text>
        <text class="action-text">我的课程</text>
      </view>
      <view class="action-item" bindtap="goToClasses">
        <text class="action-icon">🏫</text>
        <text class="action-text">我的班级</text>
      </view>
      <view class="action-item" bindtap="goToStudents">
        <text class="action-icon">👥</text>
        <text class="action-text">学生管理</text>
      </view>
      <view class="action-item" bindtap="goToLessons">
        <text class="action-icon">📝</text>
        <text class="action-text">课时记录</text>
      </view>
      <view class="action-item" bindtap="goToDashboard" wx:if="{{role === 'Admin' || role === 'SuperAdmin'}}">
        <text class="action-icon">📊</text>
        <text class="action-text">运营看板</text>
      </view>
      <view class="action-item" bindtap="goToReminders">
        <text class="action-icon">🔔</text>
        <text class="action-text">我的提醒</text>
      </view>
    </view>
  </view>

  <!-- ========== 学生端快捷入口 ========== -->
  <view class="quick-actions" wx:if="{{role === 'Student'}}">
    <view class="action-grid">
      <view class="action-item" bindtap="goToMyClasses">
        <text class="action-icon">🏫</text>
        <text class="action-text">我的班级</text>
      </view>
      <view class="action-item" bindtap="goToMyLessonRecords">
        <text class="action-icon">📝</text>
        <text class="action-text">课时记录</text>
      </view>
      <view class="action-item" bindtap="goToReminders">
        <text class="action-icon">🔔</text>
        <text class="action-text">我的提醒</text>
      </view>
    </view>
  </view>

  <!-- ========== 教师端今日概览 ========== -->
  <view class="section" wx:if="{{role !== 'Student'}}">
    <view class="section-header">
      <text class="section-title">今日概览</text>
      <text class="section-refresh" bindtap="retryLoad" wx:if="{{error}}">点击重试</text>
    </view>
    
    <!-- 加载中状态 -->
    <view class="overview-card" wx:if="{{loading}}">
      <view class="skeleton-item">
        <view class="skeleton-value"></view>
        <view class="skeleton-label"></view>
      </view>
      <view class="skeleton-item">
        <view class="skeleton-value"></view>
        <view class="skeleton-label"></view>
      </view>
      <view class="skeleton-item">
        <view class="skeleton-value"></view>
        <view class="skeleton-label"></view>
      </view>
    </view>

    <!-- 错误状态 -->
    <view class="overview-card error-card" wx:elif="{{error}}">
      <view class="error-content">
        <text class="error-icon">⚠️</text>
        <text class="error-text">{{error}}</text>
        <text class="error-hint" bindtap="retryLoad">点击重试</text>
      </view>
    </view>

    <!-- 正常数据 -->
    <view class="overview-card" wx:else>
      <view class="overview-item">
        <text class="overview-value {{todayLessons > 0 ? 'has-data' : ''}}">{{todayLessons}}</text>
        <text class="overview-label">今日课次</text>
      </view>
      <view class="overview-item">
        <text class="overview-value {{pendingAttendance > 0 ? 'warning' : ''}}">{{pendingAttendance}}</text>
        <text class="overview-label">待考勤</text>
      </view>
      <view class="overview-item">
        <text class="overview-value">{{totalStudents}}</text>
        <text class="overview-label">在籍学生</text>
      </view>
      <view class="overview-item">
        <text class="overview-value">{{totalClasses}}</text>
        <text class="overview-label">我的班级</text>
      </view>
    </view>
  </view>

  <!-- ========== 学生端学习概览 ========== -->
  <view class="section" wx:if="{{role === 'Student'}}">
    <view class="section-header">
      <text class="section-title">我的学习</text>
      <text class="section-refresh" bindtap="retryLoad" wx:if="{{error}}">点击重试</text>
    </view>

    <!-- 加载中 -->
    <view class="overview-card" wx:if="{{loading}}">
      <view class="skeleton-item">
        <view class="skeleton-value"></view>
        <view class="skeleton-label"></view>
      </view>
    </view>

    <!-- 错误状态 -->
    <view class="overview-card error-card" wx:elif="{{error}}">
      <view class="error-content">
        <text class="error-icon">⚠️</text>
        <text class="error-text">{{error}}</text>
        <text class="error-hint" bindtap="retryLoad">点击重试</text>
      </view>
    </view>

    <!-- 正常数据 -->
    <view wx:else>
      <!-- 我的合同 -->
      <view class="overview-card" wx:if="{{myContracts.length > 0}}">
        <view class="contract-list">
          <view class="contract-item" wx:for="{{myContracts}}" wx:key="id">
            <text class="contract-name">{{item.courseName || item.name || '课程合同'}}</text>
            <text class="contract-info">{{item.totalLessons || 0}} 课时</text>
          </view>
        </view>
      </view>
      <view class="overview-card" wx:else>
        <view class="empty-hint">
          <text class="empty-text">暂无合同信息</text>
        </view>
      </view>

      <!-- 最近课时 -->
      <view class="section-header" style="margin-top: 20rpx;">
        <text class="section-title">最近课时</text>
      </view>
      <view class="overview-card" wx:if="{{recentLessons.length > 0}}">
        <view class="lesson-list">
          <view class="lesson-item" wx:for="{{recentLessons}}" wx:key="id">
            <view class="lesson-info">
              <text class="lesson-name">{{item.className || item.courseName || '课时'}}</text>
              <text class="lesson-date">{{item.lessonDate || ''}}</text>
            </view>
            <text class="lesson-status {{item.status === 'COMPLETED' ? 'status-done' : ''}}">{{item.status === 'COMPLETED' ? '已完成' : item.status || '待上课'}}</text>
          </view>
        </view>
      </view>
      <view class="overview-card" wx:else>
        <view class="empty-hint">
          <text class="empty-text">暂无课时记录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作提示（仅教师端） -->
  <view class="tips-card" wx:if="{{role !== 'Student' && pendingAttendance > 0}}">
    <view class="tips-content">
      <text class="tips-icon">💡</text>
      <text class="tips-text">您有 {{pendingAttendance}} 条待考勤记录，点击「课时记录」完成打卡</text>
    </view>
  </view>
</view>
