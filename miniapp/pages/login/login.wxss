/* pages/login/login.wxss */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  min-height: 100vh;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-form {
  width: 100%;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  height: 90rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #1890ff;
  color: #ffffff;
  font-size: 34rpx;
  border-radius: 12rpx;
  margin-top: 40rpx;
}

.wechat-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #07c160;
  color: #ffffff;
  font-size: 34rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}