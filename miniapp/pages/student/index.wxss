/* pages/student/index.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 欢迎卡片 */
.welcome-card {
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.welcome-text {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.student-code {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  color: #999;
  font-size: 28rpx;
}

/* 错误 */
.error-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
}

.retry-btn {
  font-size: 28rpx;
  color: #1890ff;
  margin-top: 20rpx;
  padding: 10rpx 30rpx;
  border: 2rpx solid #1890ff;
  border-radius: 8rpx;
}

/* Section */
.section {
  margin-bottom: 20rpx;
}

.section-header {
  padding: 20rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 合同卡片 */
.contract-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.contract-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.contract-subject {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.contract-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.status-active {
  background: #f6ffed;
  color: #52c41a;
  border: 2rpx solid #b7eb8f;
}

.status-inactive {
  background: #fff7e6;
  color: #fa8c16;
  border: 2rpx solid #ffd591;
}

.contract-body {
  display: flex;
  justify-content: space-between;
}

.contract-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.info-value.highlight {
  color: #1890ff;
  font-size: 40rpx;
}

.info-value.date {
  font-size: 22rpx;
  color: #666;
  font-weight: normal;
}

/* 课时列表 */
.lesson-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}

.lesson-date {
  margin-right: 20rpx;
}

.date-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.lesson-info {
  display: flex;
  flex: 1;
  justify-content: space-between;
  align-items: center;
}

.lesson-time {
  font-size: 26rpx;
  color: #666;
}

.lesson-status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.tag-present {
  background: #f6ffed;
  color: #52c41a;
}

.tag-absent {
  background: #fff2f0;
  color: #ff4d4f;
}

.tag-other {
  background: #fff7e6;
  color: #fa8c16;
}

/* 空状态 */
.empty {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
  background: #fff;
  border-radius: 12rpx;
  color: #999;
  font-size: 26rpx;
}

.section-action {
  font-size: 26rpx;
  color: #1890ff;
}
