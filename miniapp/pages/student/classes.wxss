/* pages/student/classes.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  padding: 20rpx 0;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  color: #999;
  font-size: 28rpx;
}

.error-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  background: #fff;
  border-radius: 12rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
}

.retry-btn {
  font-size: 28rpx;
  color: #1890ff;
  margin-top: 20rpx;
  padding: 10rpx 30rpx;
  border: 2rpx solid #1890ff;
  border-radius: 8rpx;
}

.class-list {
  padding-top: 10rpx;
}

.class-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.class-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.class-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.class-code {
  font-size: 22rpx;
  color: #999;
}

.class-progress {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #52c41a);
  border-radius: 8rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
}

.class-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

.empty {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
