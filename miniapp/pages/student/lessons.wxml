<!-- pages/student/lessons.wxml -->
<view class="container">
  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Error -->
  <view wx:elif="{{error}}" class="error-state">
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="loadLessons">重试</view>
  </view>

  <!-- Empty -->
  <view wx:elif="{{allLessons.length === 0 && !loading}}" class="empty-state">
    <text class="empty-text">暂无课时记录</text>
  </view>

  <block wx:else>
    <!-- 统计概览 -->
    <view class="stats-card">
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-value">{{stats.total}}</text>
          <text class="stats-label">总课时</text>
        </view>
        <view class="stats-item">
          <text class="stats-value stats-present">{{stats.present}}</text>
          <text class="stats-label">已到</text>
        </view>
        <view class="stats-item">
          <text class="stats-value stats-absent">{{stats.absent}}</text>
          <text class="stats-label">缺勤</text>
        </view>
        <view class="stats-item">
          <text class="stats-value stats-late">{{stats.late}}</text>
          <text class="stats-label">迟到</text>
        </view>
      </view>
    </view>

    <!-- 筛选标签 -->
    <view class="filter-tabs">
      <view class="filter-tab {{filterStatus === 'ALL' ? 'active' : ''}}" bindtap="filterByStatus" data-status="ALL">全部</view>
      <view class="filter-tab {{filterStatus === 'PRESENT' ? 'active' : ''}}" bindtap="filterByStatus" data-status="PRESENT">已到</view>
      <view class="filter-tab {{filterStatus === 'ABSENT' ? 'active' : ''}}" bindtap="filterByStatus" data-status="ABSENT">缺勤</view>
      <view class="filter-tab {{filterStatus === 'LATE' ? 'active' : ''}}" bindtap="filterByStatus" data-status="LATE">迟到</view>
      <view class="filter-tab {{filterStatus === 'LEAVE' ? 'active' : ''}}" bindtap="filterByStatus" data-status="LEAVE">请假</view>
    </view>

    <!-- List -->
    <view class="lesson-list">
      <view wx:for="{{lessons}}" wx:key="lessonId" class="lesson-item">
        <view class="lesson-date">
          <text class="date-text">{{item.lessonDate}}</text>
        </view>
        <view class="lesson-info">
          <text class="course-name">{{item.courseName || item.topic || '未知课程'}}</text>
          <text class="class-name">{{item.className || '未知班级'}}</text>
          <view class="lesson-bottom">
            <text class="lesson-time">{{item.startTime}} - {{item.endTime}}</text>
            <text class="lesson-status {{item.status === 'PRESENT' ? 'tag-present' : item.status === 'ABSENT' ? 'tag-absent' : item.status === 'LATE' ? 'tag-late' : item.status === 'LEAVE' ? 'tag-leave' : 'tag-other'}}">
              {{item.status === 'PRESENT' ? '已到' : item.status === 'ABSENT' ? '缺课' : item.status === 'LATE' ? '迟到' : item.status === 'LEAVE' ? '请假' : '待确认'}}
            </text>
          </view>
        </view>
      </view>
      <view wx:if="{{lessons.length === 0}}" class="empty-state">
        <text class="empty-text">无匹配记录</text>
      </view>
    </view>
  </block>
</view>
