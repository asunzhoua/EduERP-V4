/* pages/student/class-detail/index.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 加载/错误状态 */
.loading-state, .error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e6f7ff;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.retry-btn {
  padding: 16rpx 40rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 头部 */
.detail-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.class-name {
  font-size: 36rpx;
  font-weight: bold;
}

.class-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.2);
}

.class-code-label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

/* 信息区块 */
.info-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

/* 进度区域 */
.progress-area {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-bar-big {
  flex: 1;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill-big {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #52c41a);
  border-radius: 12rpx;
}

.progress-percent {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
}

.progress-detail {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

/* 教师区域 */
.teacher-area {
  display: flex;
  align-items: center;
}

.teacher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.t-avatar-img {
  width: 100%;
  height: 100%;
}

.teacher-info {
  display: flex;
  flex-direction: column;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.teacher-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 操作区域 */
.action-section {
  padding: 10rpx 0 40rpx;
}

.action-btn {
  width: 100%;
  padding: 24rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
}
