/* pages/student/attendance.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.loading-state, .error-state, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #ddd;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text, .empty-text {
  font-size: 28rpx;
  color: #999;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.retry-btn {
  font-size: 28rpx;
  color: #1890ff;
  padding: 10rpx 30rpx;
  border: 2rpx solid #1890ff;
  border-radius: 8rpx;
}

.attendance-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.attendance-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
}

.attendance-date {
  display: flex;
  flex-direction: column;
  width: 180rpx;
  margin-right: 16rpx;
}

.date-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.time-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.attendance-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.course-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.class-name {
  font-size: 26rpx;
  color: #999;
}

.attendance-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.status-PRESENT {
  background: #f6ffed;
  color: #52c41a;
  border: 2rpx solid #b7eb8f;
}

.status-ABSENT {
  background: #fff2f0;
  color: #ff4d4f;
  border: 2rpx solid #ffccc7;
}

.status-LATE {
  background: #fff7e6;
  color: #fa8c16;
  border: 2rpx solid #ffd591;
}

.status-LEAVE {
  background: #e6f7ff;
  color: #1890ff;
  border: 2rpx solid #91d5ff;
}

.status-PENDING, .status-null {
  background: #f5f5f5;
  color: #999;
  border: 2rpx solid #d9d9d9;
}
