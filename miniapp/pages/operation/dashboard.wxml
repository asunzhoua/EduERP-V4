<!--pages/operation/dashboard.wxml-->
<view class="page-container">

  <!-- ========== 无权限状态 ========== -->
  <view class="no-permission" wx:if="{{!hasPermission}}">
    <text class="no-perm-icon">🔒</text>
    <text class="no-perm-title">无访问权限</text>
    <text class="no-perm-desc">该页面仅对管理员开放</text>
    <view class="no-perm-btn" bindtap="goBack">
      <text class="no-perm-btn-text">返回首页</text>
    </view>
  </view>

  <!-- ========== 有权限 — 正常内容 ========== -->
  <block wx:if="{{hasPermission}}">

    <!-- 顶部：时间范围选择 + 操作按钮 -->
    <view class="top-bar">
      <view class="top-bar-left">
        <view class="action-btn {{refreshing ? 'action-btn-disabled' : ''}}" bindtap="onManualRefresh">
          <text class="action-icon {{refreshing ? 'action-icon-spin' : ''}}">🔄</text>
        </view>
        <view class="action-btn" bindtap="onExportData">
          <text class="action-icon">📤</text>
        </view>
      </view>
      <view class="segmented-control">
        <view class="segment-item {{days === 7 ? 'segment-active' : ''}} {{trendLoading && days === 7 ? 'segment-loading' : ''}}" bindtap="switchDays" data-days="{{7}}">
          <text>7天</text>
        </view>
        <view class="segment-item {{days === 30 ? 'segment-active' : ''}} {{trendLoading && days === 30 ? 'segment-loading' : ''}}" bindtap="switchDays" data-days="{{30}}">
          <text>30天</text>
        </view>
      </view>
    </view>

    <!-- Tab 栏 -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab === 0 ? 'tab-active' : ''}}" bindtap="switchTab" data-index="{{0}}">
        <text class="tab-text">学员概览</text>
        <view class="tab-underline" wx:if="{{activeTab === 0}}"></view>
      </view>
      <view class="tab-item {{activeTab === 1 ? 'tab-active' : ''}}" bindtap="switchTab" data-index="{{1}}">
        <text class="tab-text">课程概览</text>
        <view class="tab-underline" wx:if="{{activeTab === 1}}"></view>
      </view>
      <view class="tab-item {{activeTab === 2 ? 'tab-active' : ''}}" bindtap="switchTab" data-index="{{2}}">
        <text class="tab-text">趋势分析</text>
        <view class="tab-underline" wx:if="{{activeTab === 2}}"></view>
      </view>
    </view>

    <!-- ========== 首次加载骨架屏 ========== -->
    <view class="content-area" wx:if="{{loading}}">
      <view class="skeleton-card">
        <view class="skeleton-grid">
          <view class="skeleton-metric" wx:for="{{4}}" wx:key="*this">
            <view class="skeleton-value"></view>
            <view class="skeleton-label"></view>
          </view>
        </view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-chart"></view>
      </view>
    </view>

    <!-- ========== 错误状态 ========== -->
    <view class="content-area" wx:elif="{{error}}">
      <view class="error-card">
        <text class="error-icon">⚠️</text>
        <text class="error-text">{{error}}</text>
        <view class="retry-btn" bindtap="retry">
          <text class="retry-btn-text">重新加载</text>
        </view>
      </view>
    </view>

    <!-- ========== Tab 1: 学员概览 ========== -->
    <scroll-view class="content-area" scroll-y wx:elif="{{activeTab === 0}}">
      <!-- 空状态引导 -->
      <view class="empty-guide" wx:if="{{isEmpty}}">
        <text class="empty-guide-icon">📋</text>
        <text class="empty-guide-text">暂无学员数据</text>
        <text class="empty-guide-hint">添加学员后即可查看统计</text>
      </view>
      <!-- 指标卡片 -->
      <view class="metric-grid">
        <view class="metric-card">
          <text class="metric-value">{{totalStudents}}</text>
          <text class="metric-unit">人</text>
          <text class="metric-label">总学员数</text>
        </view>
        <view class="metric-card">
          <text class="metric-value">{{activeStudents}}</text>
          <text class="metric-unit">人</text>
          <text class="metric-label">活跃学员数</text>
        </view>
        <view class="metric-card">
          <text class="metric-value">{{totalClasses}}</text>
          <text class="metric-unit">个</text>
          <text class="metric-label">总班级数</text>
        </view>
        <view class="metric-card">
          <text class="metric-value">{{activeRate}}</text>
          <text class="metric-unit">%</text>
          <text class="metric-label">活跃率</text>
        </view>
      </view>

      <!-- 新增学员趋势 -->
      <view class="chart-card">
        <view class="chart-title">新增学员趋势</view>
        <view class="chart-subtitle">最近{{days}}天</view>

        <!-- 趋势加载中 -->
        <view class="chart-loading" wx:if="{{trendLoading}}">
          <view class="chart-skeleton"></view>
        </view>

        <!-- 空状态 -->
        <view class="chart-empty" wx:elif="{{enrollmentTrend.length === 0}}">
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无数据</text>
        </view>

        <!-- 柱状图 -->
        <view class="bar-chart" wx:else>
          <view class="bar-item {{selectedBar === index && selectedBarType === 'enrollment' ? 'bar-item-selected' : ''}}" wx:for="{{enrollmentTrend}}" wx:key="date" bindtap="onBarTap" data-index="{{index}}" data-type="enrollment">
            <text class="bar-value {{selectedBar === index && selectedBarType === 'enrollment' ? 'bar-value-highlight' : ''}}">{{item.value}}</text>
            <view class="bar bar-animate" style="height: {{item.heightPercent}}%; animation-delay: {{index * 50}}ms"></view>
            <text class="bar-label">{{item.shortDate}}</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- ========== Tab 2: 课程概览 ========== -->
    <scroll-view class="content-area" scroll-y wx:elif="{{activeTab === 1}}">
      <!-- 空状态引导 -->
      <view class="empty-guide" wx:if="{{isEmpty}}">
        <text class="empty-guide-icon">📚</text>
        <text class="empty-guide-text">暂无课程数据</text>
        <text class="empty-guide-hint">创建课程后即可查看统计</text>
      </view>
      <!-- 指标卡片 -->
      <view class="metric-grid">
        <view class="metric-card">
          <text class="metric-value">{{totalCourses}}</text>
          <text class="metric-unit">个</text>
          <text class="metric-label">总课程数</text>
        </view>
        <view class="metric-card">
          <text class="metric-value">{{totalClasses}}</text>
          <text class="metric-unit">个</text>
          <text class="metric-label">总班级数</text>
        </view>
      </view>

      <!-- 课时完成趋势 -->
      <view class="chart-card">
        <view class="chart-title">课时完成趋势</view>
        <view class="chart-subtitle">最近{{days}}天</view>

        <!-- 趋势加载中 -->
        <view class="chart-loading" wx:if="{{trendLoading}}">
          <view class="chart-skeleton"></view>
        </view>

        <!-- 空状态 -->
        <view class="chart-empty" wx:elif="{{lessonTrend.length === 0}}">
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无数据</text>
        </view>

        <!-- 柱状图 -->
        <view class="bar-chart" wx:else>
          <view class="bar-item {{selectedBar === index && selectedBarType === 'lesson' ? 'bar-item-selected' : ''}}" wx:for="{{lessonTrend}}" wx:key="date" bindtap="onBarTap" data-index="{{index}}" data-type="lesson">
            <text class="bar-value {{selectedBar === index && selectedBarType === 'lesson' ? 'bar-value-highlight' : ''}}">{{item.value}}</text>
            <view class="bar bar-animate" style="height: {{item.heightPercent}}%; animation-delay: {{index * 50}}ms"></view>
            <text class="bar-label">{{item.shortDate}}</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- ========== Tab 3: 趋势分析 ========== -->
    <scroll-view class="content-area" scroll-y wx:elif="{{activeTab === 2}}">
      <!-- 趋势加载错误 -->
      <view class="error-card" wx:if="{{trendError}}">
        <text class="error-icon">⚠️</text>
        <text class="error-text">{{trendError}}</text>
        <view class="retry-btn" bindtap="retryTrend">
          <text class="retry-btn-text">重新加载</text>
        </view>
      </view>
      <block wx:else>
      <!-- 学员增长趋势 -->
      <view class="chart-card">
        <view class="chart-title">学员增长趋势</view>
        <view class="chart-subtitle">最近{{days}}天</view>

        <view class="chart-loading" wx:if="{{trendLoading}}">
          <view class="chart-skeleton"></view>
        </view>

        <view class="chart-empty" wx:elif="{{enrollmentTrend.length === 0}}">
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无数据</text>
        </view>

        <view class="bar-chart" wx:else>
          <view class="bar-item {{selectedBar === index && selectedBarType === 'enrollment-tab2' ? 'bar-item-selected' : ''}}" wx:for="{{enrollmentTrend}}" wx:key="date" bindtap="onBarTap" data-index="{{index}}" data-type="enrollment-tab2">
            <text class="bar-value {{selectedBar === index && selectedBarType === 'enrollment-tab2' ? 'bar-value-highlight' : ''}}">{{item.value}}</text>
            <view class="bar bar-blue bar-animate" style="height: {{item.heightPercent}}%; animation-delay: {{index * 50}}ms"></view>
            <text class="bar-label">{{item.shortDate}}</text>
          </view>
        </view>
      </view>

      <!-- 课时完成趋势 -->
      <view class="chart-card">
        <view class="chart-title">课时完成趋势</view>
        <view class="chart-subtitle">最近{{days}}天</view>

        <view class="chart-loading" wx:if="{{trendLoading}}">
          <view class="chart-skeleton"></view>
        </view>

        <view class="chart-empty" wx:elif="{{lessonTrend.length === 0}}">
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无数据</text>
        </view>

        <view class="bar-chart" wx:else>
          <view class="bar-item {{selectedBar === index && selectedBarType === 'lesson-tab2' ? 'bar-item-selected' : ''}}" wx:for="{{lessonTrend}}" wx:key="date" bindtap="onBarTap" data-index="{{index}}" data-type="lesson-tab2">
            <text class="bar-value {{selectedBar === index && selectedBarType === 'lesson-tab2' ? 'bar-value-highlight' : ''}}">{{item.value}}</text>
            <view class="bar bar-green bar-animate" style="height: {{item.heightPercent}}%; animation-delay: {{index * 50}}ms"></view>
            <text class="bar-label">{{item.shortDate}}</text>
          </view>
        </view>
      </view>
      </block>
    </scroll-view>

  </block>
</view>
