# Server
SERVER_PORT=3000

# Logging
LOG_LEVEL=debug

# WeChat Mini Program (预留，待接入)
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# Redis (预留，待接入)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
