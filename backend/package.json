{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node -r tsconfig-paths/register dist/main.js",
    "seed": "node -r tsconfig-paths/register dist/database/seed-runner.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "governance:check": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/governance-dashboard.ts",
    "governance:freeze-audit": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/freeze-audit.ts",
    "governance:validate-events": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/validate-events.ts",
    "governance:validate-state-machine": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/validate-state-machine.ts",
    "governance:build-handbook": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/build-handbook.ts",
    "governance:build-adr-index": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/build-adr-index.ts",
    "governance:build-baseline": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/build-baseline.ts",
    "governance:platform": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/platform/cli.ts",
    "governance:platform:check": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/platform/cli.ts check",
    "governance:platform:list": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/platform/cli.ts list",
    "governance:platform:baseline": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/platform/cli.ts baseline",
    "governance:platform:report": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/platform/cli.ts report",
    "governance:platform:validate": "npx ts-node --project ../tsconfig.governance.json ../scripts/governance/platform/cli.ts validate",
    "governance:test": "npx jest --config jest.governance.config.js",
    "eos": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts",
    "eos:doctor": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts doctor",
    "eos:health": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts health",
    "eos:validate": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts validate",
    "eos:freeze": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts freeze",
    "eos:knowledge": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts knowledge",
    "eos:repo": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts repo",
    "eos:generate": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts generate",
    "eos:mission": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts mission",
    "dx": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts health",
    "dx:full": "npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts validate && npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts doctor && npx ts-node --project ../tsconfig.cli.json ../tools/eos-cli/index.ts health"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/typeorm": "^11.0.3",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "mysql2": "^3.22.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0",
    "uuid": "^14.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "@types/xlsx": "^0.0.35",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1",
      "^@events/(.*)$": "<rootDir>/events/$1",
      "^@database/(.*)$": "<rootDir>/database/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@utils/(.*)$": "<rootDir>/utils/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ]
  }
}
